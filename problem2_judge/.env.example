# Copy to .env and fill in. Never commit .env.

GROQ_API_KEY=
OPENAI_API_KEY=

GENERATOR_PROVIDER=groq
GENERATOR_MODEL=llama-3.3-70b-versatile

# For real self-enhancement-bias mitigation, point the judge at a DIFFERENT
# model family than the generator. Default here uses Gemma (Groq) instead of
# Llama; you can also set JUDGE_PROVIDER=openai / gpt-4o-mini for a fully
# cross-vendor judge if you have an OpenAI key.
JUDGE_PROVIDER=groq
JUDGE_MODEL=qwen/qwen3-32b
#llama-3.1-8b-instant
#qwen/qwen3-32b
#openai/gpt-oss-20b

PASS_THRESHOLD=3.5
LOG_DIR=./logs
